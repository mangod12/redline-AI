# =============================================================================
# Redline AI — Environment Variables
# Copy to .env and fill in values before running
# =============================================================================

# ---- App -------------------------------------------------------------------
APP_ENV=development          # development | production
SECRET_KEY=CHANGE_ME         # python -c "import secrets; print(secrets.token_urlsafe(64))"

# ---- PostgreSQL -------------------------------------------------------------
USE_SQLITE=true              # Set false for production (PostgreSQL required)
POSTGRES_USER=redline_user
POSTGRES_PASSWORD=CHANGE_ME_generate_a_random_password
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=redline

# ---- Redis ------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---- Whisper STT ------------------------------------------------------------
WHISPER_MODEL_SIZE=small     # tiny | base | small | medium | large

# ---- ML Service (Stage2 pipeline) ------------------------------------------
ML_SERVICE_URL=http://localhost:8001

# ---- CORS -------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- Twilio (optional) -----------------------------------------------------
TWILIO_AUTH_TOKEN=

# ---- Grafana ----------------------------------------------------------------
GF_ADMIN_PASSWORD=CHANGE_ME_grafana_password

# ---- Gunicorn (Docker) -----------------------------------------------------
GUNICORN_WORKERS=2

# ---- Load Testing -----------------------------------------------------------
LOCUST_AUTH_TOKEN=            # JWT for locust; or use LOCUST_USERNAME/LOCUST_PASSWORD
LOCUST_USERNAME=admin@redline.ai
LOCUST_PASSWORD=
